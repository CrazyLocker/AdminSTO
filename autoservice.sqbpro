-- ДОБАВЛЕНИЕ КОЛОНКИ duration В ТАБЛИЦУ services
-- ============================================
ALTER TABLE services ADD COLUMN duration INTEGER DEFAULT 60;
ALTER TABLE services ADD COLUMN part_number TEXT DEFAULT '';

-- ============================================
-- ОЧИСТКА СТАРЫХ ДАННЫХ
-- ============================================
DELETE FROM order_parts;
DELETE FROM order_services;
DELETE FROM orders;
DELETE FROM appointments;
DELETE FROM spare_parts;
DELETE FROM services;
DELETE FROM clients;
DELETE FROM sqlite_sequence;


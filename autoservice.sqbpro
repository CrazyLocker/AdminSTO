-- ============================================
-- 5. ЗАПИСИ В КАЛЕНДАРЕ (5 штук на разные даты)
-- ============================================

-- Запись №1: Иван Петров, сегодня, 09:00
INSERT INTO appointments (client_id, order_id, master_name, service_name, appointment_date, appointment_time, status) 
VALUES (1, NULL, 'Иван', 'Замена масла', date('now'), '09:00', 'ЗАПЛАНИРОВАНО');

-- Запись №2: Елена Смирнова, завтра, 10:30
INSERT INTO appointments (client_id, order_id, master_name, service_name, appointment_date, appointment_time, status) 
VALUES (2, NULL, 'Иван', 'Диагностика двигателя', date('now', '+1 day'), '10:30', 'ЗАПЛАНИРОВАНО');

-- Запись №3: Сергей Козлов, послезавтра, 11:00
INSERT INTO appointments (client_id, order_id, master_name, service_name, appointment_date, appointment_time, status) 
VALUES (3, NULL, 'Петр', 'Шиномонтаж', date('now', '+2 days'), '11:00', 'ЗАПЛАНИРОВАНО');

-- Запись №4: Ольга Новикова, через 3 дня, 14:00
INSERT INTO appointments (client_id, order_id, master_name, service_name, appointment_date, appointment_time, status) 
VALUES (4, NULL, 'Сергей', 'Замена тормозных колодок', date('now', '+3 days'), '14:00', 'ЗАПЛАНИРОВАНО');

-- Запись №5: Дмитрий Морозов, через 5 дней, 16:30
INSERT INTO appointments (client_id, order_id, master_name, service_name, appointment_date, appointment_time, status) 
VALUES (5, NULL, 'Антон', 'Развал-схождение', date('now', '+5 days'), '16:30', 'ЗАПЛАНИРОВАНО');

-- ============================================
-- 6. ОБНОВЛЕНИЕ ОСТАТКОВ НА СКЛАДЕ (списываем то, что ушло в заказы)
-- ============================================
UPDATE spare_parts SET stock = stock - 1 WHERE name = 'Масло моторное 5W-30';
UPDATE spare_parts SET stock = stock - 1 WHERE name = 'Свечи зажигания (комплект)';
UPDATE spare_parts SET stock = stock - 1 WHERE name = 'Тормозные колодки передние';

-- ============================================
-- 7. ПРОВЕРКА (вывод статистики)
-- ============================================
SELECT 'Клиентов: ' || COUNT(*) FROM clients
UNION ALL
SELECT 'Услуг: ' || COUNT(*) FROM services
UNION ALL
SELECT 'Запчастей: ' || COUNT(*) FROM spare_parts
UNION ALL
SELECT 'Записей: ' || COUNT(*) FROM appointments
UNION ALL
SELECT 'Заказов: ' || COUNT(*) FROM orders;</sql><current_tab id="0"/></tab_sql></sqlb_project>

('Замена масла', 1500),
('Диагностика двигателя', 1200),
('Замена тормозных колодок', 2500),
('Шиномонтаж', 2000),
('Развал-схождение', 1800),
('Замена ремня ГРМ', 4500),
('Замена свечей зажигания', 1200),
('Замена масла в АКПП', 3000),
('Компьютерная диагностика', 1500),
('Заправка кондиционера', 2500);

-- ============================================
-- 3. ЗАПЧАСТИ (10 штук)
-- ============================================
INSERT INTO spare_parts (name, purchase_price, retail_price, stock) VALUES
('Масло моторное 5W-30', 800, 1200, 20),
('Масляный фильтр', 200, 400, 25),
('Тормозные колодки передние', 1200, 2000, 10),
('Тормозные колодки задние', 1100, 1900, 8),
('Воздушный фильтр', 300, 600, 15),
('Свечи зажигания (комплект)', 400, 800, 12),
('Ремень ГРМ', 1500, 2500, 6),
('Фильтр салона', 250, 500, 18),
('Жидкость тормозная', 300, 500, 10),
('Антифриз', 400, 700, 8);

-- ============================================
-- 4. ЗАКАЗЫ (для демонстрации последнего ремонта)
-- ============================================

-- Заказ для Ивана Петрова (закрыт) - последний ремонт
INSERT INTO orders (id, client_id, status, total, created_date) 
VALUES ('ZAK-01/01/25-00001', 1, 'ЗАКРЫТ', 2700, '2025-01-15 10:30:00');

="101"/><column index="5" value="125"/><column index="6" value="169"/><column index="7" value="93"/><column index="8" value="72"/><column index="9" value="38"/><column index="10" value="66"/><column index="11" value="53"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- ============================================
-- СОЗДАНИЕ ТАБЛИЦ
-- ============================================

-- Категории
CREATE TABLE categories (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    parent_id INTEGER,
    type TEXT NOT NULL,
    FOREIGN KEY (parent_id) REFERENCES categories(id)
);

-- Услуги
CREATE TABLE services (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    category_id INTEGER,
    name TEXT NOT NULL,
    price REAL NOT NULL,
    duration INTEGER DEFAULT 60,
    part_number TEXT,
    FOREIGN KEY (category_id) REFERENCES categories(id)
);

-- Запчасти
CREATE TABLE spare_parts (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    category_id INTEGER,
    name TEXT NOT NULL,
    part_number TEXT,
    manufacturer TEXT,
    compatible_models TEXT,
    purchase_price REAL,
    retail_price REAL NOT NULL,
    stock INTEGER DEFAULT 0,
    min_stock INTEGER DEFAULT 0,
    location TEXT,
    FOREIGN KEY (category_id) REFERENCES categories(id)
);

-- Клиенты
CREATE TABLE clients (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    phone TEXT NOT NULL,
    car_model TEXT NOT NULL,
    car_number TEXT NOT NULL
);

-- Заказы
CREATE TABLE orders (
    id TEXT PRIMARY KEY,
    client_id INTEGER NOT NULL,
    status TEXT NOT NULL,
    total REAL NOT NULL,
    created_date TEXT NOT NULL,
    FOREIGN KEY (client_id) REFERENCES clients(id)
);

-- Услуги в заказе
CREATE TABLE order_services (
    order_id TEXT NOT NULL,
    service_name TEXT NOT NULL,
    price REAL NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE
);

-- Запчасти в заказе
CREATE TABLE order_parts (
    order_id TEXT NOT NULL,
    part_name TEXT NOT NULL,
    price REAL NOT NULL,
    quantity INTEGER NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE
);

-- Записи в календаре
CREATE TABLE appointments (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id INTEGER NOT NULL,
    order_id TEXT,
    master_name TEXT NOT NULL,
    service_name TEXT NOT NULL,
    appointment_date TEXT NOT NULL,
    appointment_time TEXT NOT NULL,
    status TEXT NOT NULL,
    FOREIGN KEY (client_id) REFERENCES clients(id),
    FOREIGN KEY (order_id) REFERENCES orders(id)
);


-- ============================================
-- 9. ПРОВЕРКА (вывод статистики)
-- ============================================
SELECT 'Клиентов: ' || COUNT(*) FROM clients;
SELECT 'Услуг: ' || COUNT(*) FROM services;
SELECT 'Запчастей: ' || COUNT(*) FROM spare_parts;
SELECT 'Заказов: ' || COUNT(*) FROM orders;
SELECT 'Записей: ' || COUNT(*) FROM appointments;</sql><current_tab id="0"/></tab_sql></sqlb_project>
